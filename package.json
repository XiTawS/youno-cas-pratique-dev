{
  "name": "youno-cas-pratique-dev",
  "version": "0.1.0",
  "private": true,
  "description": "Cas pratique technique - Développeur (Alternance/Stage) - Youno",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter \"./packages/*\" build && pnpm --filter \"./apps/*\" build",
    "lint": "pnpm --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml,yml}\"",
    "typecheck": "pnpm --recursive typecheck",
    "test": "pnpm --recursive --workspace-concurrency=1 run test"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  }
}
