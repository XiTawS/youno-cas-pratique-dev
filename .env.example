# Modèle d'environnement à la racine du monorepo.
# Convention : copier ce fichier en `.env.local` (gitignored, secrets locaux).
# Convention Vite : .env.local override .env. Les deux sont chargés par
# apps/api/src/lib/env.ts (dotenv) et par Vite côté front (envDir = racine).
# Validation Zod au démarrage de l'API : fail-fast si une var requise manque.
# Aucune valeur réelle ne doit être versionnée.

# === API (apps/api) ===
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# === Auth Clerk (étape 5) ===
# Secret key côté serveur - ne JAMAIS exposer ni partager dans des chats.
# Récupérée depuis https://dashboard.clerk.com → Configure → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Publishable key - utilisée côté API (vérification JWT) ET côté front
# (init du <ClerkProvider>). Valeur unique : Vite la rend dispo sous
# import.meta.env.VITE_CLERK_PUBLISHABLE_KEY via le `define` de vite.config.ts.
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Allowlist email applicative : double-vérif au-delà de la config Clerk dashboard.
# Format: emails séparés par virgule, normalisés en lowercase à la validation.
AUTH_ALLOWED_EMAILS=xitaws@proton.me,christian.lim@youno.fr,kaio.araujo@youno.fr,martin.thomas@youno.fr

# === Front (apps/web) ===
VITE_API_URL=http://localhost:3000

# === Database Neon ===
# DATABASE_URL=

# === Firecrawl (J2 - scraping) ===
# Clé API depuis https://firecrawl.dev → Account → API Keys
# Free tier 500 credits one-time, sans CB
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
