{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@youno/shared": ["../../packages/shared/src/index.ts"],
      "@youno/shared/schemas/*": ["../../packages/shared/src/schemas/*.ts"]
    },
    "noEmit": true
  },
  "include": ["src", "vite.config.ts"]
}
